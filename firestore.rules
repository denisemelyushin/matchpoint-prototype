rules_version = '2';

// Matchpoint Pro security rules.
//
// Model:
//   - Public read for users, posts (unless private), games (unless private).
//   - Writes require Firebase Auth; users can only mutate their own content.
//   - Private posts/games are visible only to the author/participants.
//   - Chats are strictly scoped to the two participants.
//
// Deploy:  firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ---- users ----------------------------------------------------------
    // Profiles are public reads (signed-in or guest). Only the owner can
    // write their own doc.
    match /users/{userId} {
      allow read: if true;
      allow create: if isSelf(userId)
                    && request.resource.data.name is string
                    && request.resource.data.email is string;
      allow update: if isSelf(userId);
      // Owner can delete their own profile as part of the account-deletion
      // purge (client-side cleanup before Firebase Auth `deleteUser()`).
      allow delete: if isSelf(userId);
    }

    // ---- posts ----------------------------------------------------------
    match /posts/{postId} {
      // Reads are open; `isPrivate` is enforced as a client-side display
      // filter in this prototype (Firestore list queries can't evaluate
      // doc-field-dependent rules cleanly).
      allow read: if true;

      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.content is string
                    && request.resource.data.content.size() > 0
                    && request.resource.data.likeCount == 0
                    && request.resource.data.commentCount == 0;

      // The author can edit privacy / content; anyone signed in can update
      // the denormalised likeCount + commentCount (those are mutated by the
      // like/comment subcollection writes below).
      allow update: if (isSignedIn() && resource.data.userId == request.auth.uid)
                    || (isSignedIn()
                        && onlyChanges(['likeCount', 'commentCount']));

      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.content is string
                      && request.resource.data.content.size() > 0;
        allow update: if false;
        // Author can delete their own comment. The post author can also
        // delete any comment on their post (needed for the account-purge
        // to tear down a post's subcollection before deleting the post).
        allow delete: if isSignedIn()
                      && (
                        resource.data.userId == request.auth.uid
                        || get(/databases/$(database)/documents/posts/$(postId))
                             .data.userId == request.auth.uid
                      );
      }

      match /likes/{userId} {
        allow read: if true;
        // A like doc's id equals the liking user's uid, and it must also
        // carry a matching userId field so collection-group queries can
        // filter by it.
        allow create: if isSelf(userId)
                      && request.resource.data.userId == userId;
        // Liking user can unlike; post author can also clear likes when
        // tearing down their post during account deletion.
        allow delete: if isSelf(userId)
                      || (
                        isSignedIn()
                        && get(/databases/$(database)/documents/posts/$(postId))
                             .data.userId == request.auth.uid
                      );
        allow update: if false;
      }
    }

    // Collection-group reads for comments + likes. Firestore requires these
    // top-level rules even when the matching subcollection rule already
    // grants access, because a collection-group query is not bound to any
    // specific parent path.
    match /{path=**}/comments/{commentId} {
      allow read: if true;
    }
    match /{path=**}/likes/{likeId} {
      allow read: if true;
    }

    // ---- games ----------------------------------------------------------
    match /games/{gameId} {
      // See posts — privacy is client-side in the prototype.
      allow read: if true;

      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.auth.uid in request.resource.data.playerIds
                    && request.resource.data.playerCount ==
                       request.resource.data.playerIds.size();

      // Host can fully edit. Any signed-in user can join/leave by flipping
      // their own presence in playerIds (length must stay within maxPlayers).
      allow update: if (isSignedIn() && resource.data.userId == request.auth.uid)
                    || isJoinOrLeave();

      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ---- chats ----------------------------------------------------------
    match /chats/{chatId} {
      allow read: if isSignedIn()
                  && request.auth.uid in resource.data.participantIds;

      allow create: if isSignedIn()
                    && request.resource.data.participantIds.size() == 2
                    && request.auth.uid in request.resource.data.participantIds;

      allow update: if isSignedIn()
                    && request.auth.uid in resource.data.participantIds;

      // A participant can delete the whole chat as part of the account-
      // deletion purge. The messages subcollection must be cleared by the
      // client before this delete runs (Firestore doesn't cascade).
      allow delete: if isSignedIn()
                    && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read: if isSignedIn()
                    && request.auth.uid in
                       get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
        allow create: if isSignedIn()
                      && request.resource.data.senderId == request.auth.uid
                      && request.auth.uid in
                         get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds
                      && request.resource.data.content is string
                      && request.resource.data.content.size() > 0;
        allow update: if false;
        // Only permitted during the account-purge: a chat participant may
        // delete any message in the chat so the subcollection can be
        // cleared before the chat doc itself is removed.
        allow delete: if isSignedIn()
                      && request.auth.uid in
                         get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
      }
    }

    // ---- helpers --------------------------------------------------------

    // True if the update only touches the supplied fields (all other fields
    // are unchanged between `resource` and `request.resource`).
    function onlyChanges(fields) {
      return request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(fields);
    }

    // Valid "join" or "leave" on a game: only playerIds / playerCount move,
    // the caller is adding or removing *themselves*, and player count stays
    // within the declared maximum.
    function isJoinOrLeave() {
      return isSignedIn()
             && onlyChanges(['playerIds', 'playerCount'])
             && request.resource.data.playerCount ==
                request.resource.data.playerIds.size()
             && request.resource.data.playerIds.size() <=
                resource.data.maxPlayers
             && (
                  // joining
                  (
                    !(request.auth.uid in resource.data.playerIds)
                    && request.auth.uid in request.resource.data.playerIds
                    && resource.data.playerIds.size() + 1 ==
                       request.resource.data.playerIds.size()
                  )
                  ||
                  // leaving (host can't leave; blocked elsewhere, but enforce here too)
                  (
                    request.auth.uid in resource.data.playerIds
                    && !(request.auth.uid in request.resource.data.playerIds)
                    && resource.data.playerIds.size() - 1 ==
                       request.resource.data.playerIds.size()
                    && resource.data.userId != request.auth.uid
                  )
                );
    }
  }
}
